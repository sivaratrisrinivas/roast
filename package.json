{
  "name": "roast",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.2.23",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"bun run dev:client\" \"bun run dev:server\"",
    "dev:client": "./scripts/build-client.sh --watch",
    "dev:server": "./scripts/bun.sh --watch server/index.mjs",
    "build": "./scripts/build-client.sh --minify",
    "preview": "./scripts/bun.sh server/index.mjs",
    "start": "./scripts/bun.sh server/index.mjs"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
